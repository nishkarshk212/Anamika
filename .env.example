# ============================================
# AnnieXMusic Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Command: cp .env.example .env

# ── Core Bot Configuration (Required) ──────────────────────────────────────────
API_ID=your_api_id_here
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
OWNER_ID=your_telegram_user_id_here

# ── Database Configuration (Required) ──────────────────────────────────────────
MONGO_DB_URI=your_mongodb_connection_string_here

# ── Session Strings (Required - At least one) ──────────────────────────────────
STRING_SESSION=your_pyrogram_session_string_here
STRING_SESSION2=
STRING_SESSION3=
STRING_SESSION4=
STRING_SESSION5=

# ── Logging (Optional) ─────────────────────────────────────────────────────────
LOGGER_ID=-100xxxxxxxxxx

# ── External APIs (Optional but Recommended) ───────────────────────────────────
COOKIE_URL=
DEEP_API=
API_KEY=your_api_key_here
API_URL=http://api.nubcoder.com
VIDEO_API_URL=http://api.nubcoder.com

# Additional Service APIs
RMBG_API_KEY=your_remove_bg_api_key_here
PHONE_API_KEY=your_phone_validation_api_key_here
TMDB_API_KEY=your_tmdb_api_key_here
IPINFO_TOKEN=your_ipinfo_token_here
IPQUALITYSCORE_API_KEY=your_ipqs_api_key_here

# ── Spotify Integration (Optional) ─────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── Hosting & Deployment (Optional) ────────────────────────────────────────────
HEROKU_APP_NAME=
HEROKU_API_KEY=
GIT_TOKEN=

# ── Support Links (Optional) ───────────────────────────────────────────────────
SUPPORT_CHANNEL=https://t.me/your_support_channel
SUPPORT_CHAT=https://t.me/your_support_chat

# ── Bot Customization (Optional) ───────────────────────────────────────────────
BOT_NAME=AnnieXMusic
BOT_USERNAME=your_bot_username
ASSUSERNAME=your_assistant_username
OWNER_USERNAME=your_username

# ── Limits & Timeouts (Optional - Default values shown) ────────────────────────
DURATION_LIMIT=300
SONG_DOWNLOAD_DURATION=1200
SONG_DOWNLOAD_DURATION_LIMIT=1800
TG_AUDIO_FILESIZE_LIMIT=157286400
TG_VIDEO_FILESIZE_LIMIT=1288490189
PLAYLIST_FETCH_LIMIT=30
ASSISTANT_LEAVE_TIME=3600

# ── Git Repository (Optional) ──────────────────────────────────────────────────
UPSTREAM_REPO=https://github.com/JaydenBot/AnnieXMusic
UPSTREAM_BRANCH=Master
